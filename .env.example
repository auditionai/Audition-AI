# Vertex AI Configuration
GOOGLE_CLOUD_PROJECT=your_google_cloud_project_id
GOOGLE_CLOUD_LOCATION=global
# Dùng GOOGLE_APPLICATION_CREDENTIALS nếu chạy ở máy tính (trỏ đến file)
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
# Dùng GOOGLE_CREDENTIALS_JSON nếu chạy trên Netlify/Render/Vercel
# Copy toàn bộ nội dung file JSON và dán vào đây
GOOGLE_CREDENTIALS_JSON=

# Cloudflare R2 Configuration
VITE_R2_ACCOUNT_ID=your_cloudflare_account_id
VITE_R2_ACCESS_KEY_ID=your_r2_access_key
VITE_R2_SECRET_ACCESS_KEY=your_r2_secret_key
VITE_R2_BUCKET_NAME=your_bucket_name
VITE_R2_PUBLIC_URL=your_public_r2_url

# Supabase Database (for metadata)
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_URL=your_supabase_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Secondary Supabase (sample prompts)
CAULENHAU_SUPABASE_URL=your_secondary_supabase_url
CAULENHAU_SUPABASE_ANON_KEY=your_secondary_supabase_anon_key

# Trạm Sáng Tạo / Netlify Functions
TST_API_KEY=your_tst_api_key

# PayOS / Netlify Functions
PAYOS_CLIENT_ID=your_payos_client_id
PAYOS_API_KEY=your_payos_api_key
PAYOS_CHECKSUM_KEY=your_payos_checksum_key
PAYOS_RETURN_URL=http://localhost:5173
PAYOS_CANCEL_URL=http://localhost:5173
PAYOS_WEBHOOK_URL=https://your-domain.com/api/payos-webhook
